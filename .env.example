# Required — from https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_your_key_here

# Workspace directory for Cursor SDK agents (defaults to process.cwd())
# CURSOR_CWD=/path/to/workspace

# Server
# PORT=8080
# HOST=0.0.0.0
# DEFAULT_MODEL=composer-2.5

# Optional bearer auth for the proxy itself
# AUTH_KEY=

# Agent behavior (see README.md)
# CURSOR_INCLUDE_THINKING=true
# CURSOR_ASSISTANT_TEXT_MODE=live
# CURSOR_EMIT_TOOL_CALLS=false
# CURSOR_EMIT_SPEED_ALIASES=true
# CURSOR_MODEL_ALLOWLIST=composer-2.5,claude-opus-4-8  # omit for curated default; "*" = full catalog
# CURSOR_ENABLE_SESSIONS=true
# CURSOR_AUTO_SESSION=true
# CURSOR_SESSION_TTL_MS=1800000
# CURSOR_SESSION_MAX=64
# DEBUG_STREAM=false
