# Required — from https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_your_key_here

# Workspace directory for Cursor SDK agents (defaults to process.cwd()).
# Accepts a plain directory OR a VS Code `.code-workspace` file — the latter is
# expanded to its multi-root folder list so native agents index every root.
# CURSOR_CWD=/Users/you/code/hermes.code-workspace

# Bound per-request cwd overrides (cursor_cwd field / metadata / x-cursor-cwd
# header). Comma-separated roots; a request cwd must equal or sit under one of
# them (or under CURSOR_CWD). Omit entirely to allow any cwd (unrestricted).
# NOTE: when CURSOR_CWD is a `.code-workspace`, every expanded root is validated,
# so list each folder root here — not just the workspace file's directory.
# CURSOR_CWD_ALLOWLIST=/Users/you/.hermes,/Users/you/cursor-openai-api,/Users/you/code

# Default tool mode when a request does not set cursor_tool_mode / metadata.
# auto (default) | client (Hermes orchestrator) | native (delegated leaf).
# client/auto requests carrying tools register them as native SDK customTools
# (no marker protocol); see docs/native-client-tools.md.
# CURSOR_TOOL_MODE=auto

# Server
# PORT=8080
# HOST=0.0.0.0
# DEFAULT_MODEL=composer-2.5

# Optional bearer auth for the proxy itself
# AUTH_KEY=

# Agent behavior (see README.md)
# CURSOR_INCLUDE_THINKING=true
# CURSOR_ASSISTANT_TEXT_MODE=live
# CURSOR_EMIT_TOOL_CALLS=false
# CURSOR_NATIVE_PROGRESS=false  # narrate native tool starts/results as reasoning_content (off; never in client loop)
# CURSOR_EMIT_SPEED_ALIASES=true
# CURSOR_MODEL_ALLOWLIST=composer-2.5,claude-opus-4-8  # omit for curated default; "*" = full catalog

# Client-tool filtering — trims the set of client tools registered as native
# customTools so unused schemas never cost tokens. Per-request fields/metadata
# (cursor_enabled_toolsets / cursor_tools_allow / cursor_tools_deny) override these.
# CURSOR_ENABLED_TOOLSETS=file,terminal,coding
# CURSOR_TOOL_ALLOWLIST=read_file,write_file,patch,terminal
# CURSOR_TOOL_DENYLIST=browser_*,computer_use,cronjob
# CURSOR_TOOLSETS_KEEP_UNMAPPED=true

# Tool tiers (progressive disclosure) — keeps every tool callable while rendering
# rarely-used ones as compact signatures. full (default) | tiered | brief.
# Per-request override: cursor_tool_tier.
# CURSOR_TOOL_TIER=tiered
# CURSOR_TOOL_RESIDENT=read_file,write_file,patch,search_files,terminal,delegate_task
# Append a JSONL record of every client tool call (for tuning the resident set):
# CURSOR_TOOL_USAGE_LOG=/path/to/tool-usage.jsonl
# CURSOR_ENABLE_SESSIONS=true
# CURSOR_AUTO_SESSION=true
# CURSOR_SESSION_TTL_MS=1800000
# CURSOR_SESSION_MAX=64
# DEBUG_STREAM=false
